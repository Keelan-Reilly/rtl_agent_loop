{
  "external_repo": {
    "path": "external/MAC_ARRAY_FPGA"
  },
  "search_space": {
    "ARCH_VARIANT": {
      "type": "int",
      "allowed": [0, 1, 2]
    },
    "ARRAY_M": {
      "type": "int",
      "allowed": [4, 8]
    },
    "ARRAY_N": {
      "type": "int",
      "allowed": [4, 8]
    },
    "CLUSTER_SIZE": {
      "type": "int",
      "allowed": [1, 2, 4]
    },
    "SHARE_FACTOR": {
      "type": "int",
      "allowed": [1, 2]
    },
    "DATA_WIDTH": {
      "type": "int",
      "allowed": [12, 16]
    },
    "FRAC_BITS": {
      "type": "int",
      "allowed": [6, 8]
    },
    "ACC_WIDTH": {
      "type": "int",
      "allowed": [24, 32]
    },
    "PIPE_STAGES": {
      "type": "int",
      "allowed": [1, 2]
    },
    "TILE_K": {
      "type": "int",
      "allowed": [4]
    },
    "INPUT_MEM_DEPTH": {
      "type": "int",
      "allowed": [16, 64]
    },
    "OUTPUT_MEM_DEPTH": {
      "type": "int",
      "allowed": [16, 64]
    }
  },
  "defaults": {
    "clock_hz": 100000000,
    "vivado": {
      "part": "xc7a35tcpg236-1",
      "top": "top_level",
      "xdc": "fpga/vivado/constraints/mac_array_constraints.xdc",
      "jobs": 4,
      "clock_period_ns": 10.0
    },
    "verilator": {
      "top": "top_level"
    },
    "fast_verify": {
      "mode": "verilator_lint",
      "todo": "ARCH_VARIANT is a real top_level generic. PIPE_STAGES currently models deterministic drain latency rather than a fully retimed MAC pipeline."
    }
  }
}
